    <ui:VisualElement name="bg" style="flex-grow: 1; position: relative; top: 0%; left: 0%; right: 100%; bottom: 100%; justify-content: flex-start; align-self: center; background-position-x: center 0; transform-origin: left; width: 100%; height: 100%; flex-direction: row;">
