                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="healthbar_bg" style="flex-grow: 1; position: absolute; width: 100px; height: 100px; background-image: url(&quot;project://database/Assets/UI/Sprites/ui%201.png?fileID=-1039405763&amp;guid=9e3117718489ce94f85cf2849ef8c1c7&amp;type=3#ui 1_18&quot;); align-items: center; justify-content: space-between; align-self: flex-start; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; top: 10px; left: 22px; flex-direction: column-reverse; min-width: 100px; max-width: 100px; max-height: 100px; align-content: stretch; min-height: 100px; -unity-background-scale-mode: stretch-to-fill;">
